# ============================================================================
# .gitignore для проекта прогнозирования размера информационных каскадов
# ============================================================================

# ----------------------------------------------------------------------------
# Данные и кэши (не коммитятся)
# ----------------------------------------------------------------------------
data/raw/
data/processed/
data/embeddings/
data/interim/
*.csv
*.tsv
*.parquet
*.feather
*.h5
*.hdf5

# Исключение: маленькие справочные таблицы и метаданные могут попадать в репо
# вручную через git add -f при необходимости.

# ----------------------------------------------------------------------------
# Артефакты обучения моделей
# ----------------------------------------------------------------------------
results/checkpoints/
results/logs/
results/optuna_studies/
*.pt
*.pth
*.ckpt
*.bin
*.safetensors
mlruns/
wandb/
tensorboard/

# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ----------------------------------------------------------------------------
# Виртуальные окружения
# ----------------------------------------------------------------------------
.venv/
venv/
ENV/
env/
.env
.python-version

# ----------------------------------------------------------------------------
# Jupyter
# ----------------------------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py

# ----------------------------------------------------------------------------
# IDE и редакторы
# ----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----------------------------------------------------------------------------
# Тестирование и покрытие
# ----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# ----------------------------------------------------------------------------
# mypy / ruff
# ----------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/

# ----------------------------------------------------------------------------
# Прочее
# ----------------------------------------------------------------------------
*.log
.cache/
tmp/
scratch/
